# 构建目录（Qt Creator 默认会在源码目录外或内创建 build- 文件夹）
build-*/
*-build/

# Qt Creator 用户配置
*.user
*.user.*
*.pro.user
*.pro.user.*

# qmake 生成的临时文件
Makefile
Makefile.Debug
Makefile.Release
*.o
*.obj
*.exe
*.dll
*.so
*.dylib
*.a
*.lib
*.pdb
*.ilk
*.exp
moc_*.cpp
moc_*.h
ui_*.h
qrc_*.cpp
*.rcc

# 自动生成的资源相关
qmake_qmake_immediate.qrc
qmake_qmake_immediate.qrc.depends

# 运行时生成的数据（不提交）
data/
*.db
*.sqlite
attachments/
photos/

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# 临时备份文件
*~
*.swp
*.bak