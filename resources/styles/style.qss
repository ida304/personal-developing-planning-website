/* 全局样式（简单示例） */
QWidget {
    background-color: #f5f5f5;
    font-family: "Microsoft YaHei";
    font-size: 12px;
}

QPushButton {
    background-color: #4caf50;
    color: white;
    border: none;
    padding: 5px 12px;
    border-radius: 4px;
}
QPushButton:hover {
    background-color: #45a049;
}

QTableWidget {
    alternate-background-color: #f9f9f9;
    selection-background-color: #b0d3b0;
}
